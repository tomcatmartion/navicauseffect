generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

// ── 命盘来源 ──────────────────────────────────────────────
// ChartRecord 的来源标记，便于后续审计和分类管理
enum ChartSource {
  MANUAL       // 用户主动排盘保存
  IMPORTED     // 从 ConsultationRecord 导入
  CHAT         // 对话中自动存
  REPORT       // 报告生成时存
}

enum MembershipPlan {
  FREE
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AnalysisCategory {
  PERSONALITY
  FORTUNE
  MARRIAGE
  CAREER
  HEALTH
  PARENT_CHILD
  EMOTION
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum TemplateType {
  BASIC
  ADVANCED
}

enum RelationType {
  SELF
  SPOUSE
  CHILD
  PARENT
  SIBLING
  FRIEND
  COLLEAGUE
  OTHER
}

enum PaymentType {
  MEMBERSHIP
  PER_QUERY
  COIN_PACK
  CREDIT_PACK
}

enum PaymentChannel {
  WECHAT
  ALIPAY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PointSource {
  SHARE
  ADMIN_GRANT
  REDEEM
  INVITE
  RECHARGE
  CONSUME
  COIN_PACK
  CREDIT_PACK
  PURCHASE_REBATE
}

enum SharePlatform {
  WECHAT
  MOMENTS
  WEIBO
  QQ
  LINK
  QRCODE
  REDBOOK
  ZHIHU
}

model User {
  id            String    @id @default(cuid())
  phone         String?   @unique
  email         String?   @unique
  wechatOpenId  String?   @unique @map("wechat_openid")
  nickname      String?
  avatar        String?
  password      String?
  role          UserRole  @default(USER)
  bonusQueries  Int       @default(0) @map("bonus_queries")
  totalPoints   Int       @default(0) @map("total_points")
  inviteCode    String    @unique @map("invite_code")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  username      String?   @unique

  membership          Membership?
  consultationRecords ConsultationRecord[]
  paymentOrders       PaymentOrder[]
  pointRecords        PointRecord[]
  shareRecords        ShareRecord[]
  dailyUsages         DailyUsage[]
  identities          Identity[]
  reports             Report[]
  redeemUsages        RedeemUsage[]
  promoterProfile     PromoterProfile?

  @@map("users")
}

model Membership {
  id        String           @id @default(cuid())
  userId    String           @unique @map("user_id")
  plan      MembershipPlan   @default(FREE)
  status    MembershipStatus @default(ACTIVE)
  startDate DateTime?        @map("start_date")
  endDate   DateTime?        @map("end_date")
  pricePaid Decimal?         @map("price_paid") @db.Decimal(10, 2)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model ConsultationRecord {
  id                String   @id @default(cuid())
  userId            String?  @map("user_id")
  chartFingerprint  String?  @map("chart_fingerprint")
  birthSolarDate    String   @map("birth_solar_date")
  birthLunarDate    String?  @map("birth_lunar_date")
  birthCity         String?  @map("birth_city")
  timeIndex         Int      @map("time_index")
  gender            Gender
  astrolabeData     Json     @map("astrolabe_data")
  createdAt         DateTime @default(now()) @map("created_at")

  /** Stage1 输出 JSON（宫位评分、格局、四化） */
  stage1Snapshot   Json?    @map("stage1_snapshot")
  /** Stage2 输出 JSON（性格定性、全息底色） */
  stage2Snapshot   Json?    @map("stage2_snapshot")
  /** 最后分析的事项类型 */
  lastMatterType   String?  @map("last_matter_type")
  /** 最新编译报告 JSON */
  latestReport     Json?    @map("latest_report")
  /** 来源会话 ID */
  sourceSessionId  String?  @map("source_session_id")

  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  analyses   AIAnalysis[]

  @@index([userId, chartFingerprint])
  @@map("consultation_records")
}

model AIAnalysis {
  id             String           @id @default(cuid())
  recordId       String           @map("record_id")
  category       AnalysisCategory
  aiModelUsed    String           @map("ai_model_used")
  fullContent    String           @map("full_content") @db.LongText
  previewContent String           @map("preview_content") @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")

  record ConsultationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId, category])
  @@map("ai_analyses")
}

model PaymentOrder {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  type          PaymentType
  amount        Decimal        @db.Decimal(10, 2)
  channel       PaymentChannel
  status        PaymentStatus  @default(PENDING)
  transactionId String?        @map("transaction_id")
  metadata      Json?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_orders")
}

model AIModelConfig {
  id              String  @id @default(cuid())
  name            String
  provider        String
  apiKeyEncrypted String  @map("api_key_encrypted") @db.Text
  baseUrl         String  @map("base_url")
  modelId         String  @map("model_id")
  isActive        Boolean @default(true) @map("is_active")
  isDefault       Boolean @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("ai_model_configs")
}

model PointRecord {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  points    Int
  source    PointSource
  detail    String?
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_records")
}

model ShareRecord {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  platform     SharePlatform
  shareUrl     String        @map("share_url")
  rewardPoints Int           @default(0) @map("reward_points")
  clicks       Int           @default(0)
  createdAt    DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("share_records")
}

model MembershipPricing {
  id            String         @id @default(cuid())
  plan          MembershipPlan
  originalPrice Decimal        @map("original_price") @db.Decimal(10, 2)
  activityPrice Decimal?       @map("activity_price") @db.Decimal(10, 2)
  isActive      Boolean        @default(true) @map("is_active")
  startDate     DateTime?      @map("start_date")
  endDate       DateTime?      @map("end_date")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("membership_pricing")
}

model DailyUsage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_usages")
}

model AdminConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  configValue Json     @map("config_value")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_configs")
}

// ── RAG 精准召回：知识库元数据表 ──────────────────────────
// 与 Zvec 向量双索引：Zvec 做语义检索，MySQL 做精确元数据匹配
model ZiweiKnowledge {
  id          Int      @id @default(autoincrement())
  filePath    String   // 原始文件路径，如 sysfiles/sysknowledge/stars/武曲星.md
  title       String   // 知识标题
  content     String   @db.LongText  // 切片内容
  chunkIndex  Int      @default(0)   // 同文件第几个切片

  // 精确匹配元数据（核心！）
  stars       Json     // string[] 涉及星曜，如 ["武曲"]
  palaces     Json     // string[] 涉及宫位，如 ["命宫","财帛宫"]
  sihua       Json     // string[] 涉及四化类型，如 ["化禄","化忌"]
  domains     Json     // string[] 涉及领域，如 ["财运","事业"]
  patterns    Json     // string[] 涉及格局
  topicType   String   // "星曜本义"|"宫位含义"|"格局"|"四化"|"组合"
  timeScope   String   @default("本命") // "本命"|"大限"|"流年"

  // 向量关联
  vectorId    String?  // Zvec 中对应的向量 ID

  priority    Int      @default(5)  // 1-10，越高越重要
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([filePath, chunkIndex])
  @@index([topicType])
  @@index([timeScope])
  @@map("ziwei_knowledge")
}

// ── RAG 精准召回：标签表（systag 入库）────────────────────
model ZiweiTag {
  id        Int      @id @default(autoincrement())
  tagType   String   // "predict_item" | "star_nature" | "palace_item" | "asterism_item" | "rules_item"
  name      String   // 标签名，如"财运专项"、"十四主星"
  desc      String   @db.Text
  keywords  Json     // string[] 关键词数组
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([name, tagType])
  @@index([tagType])
  @@map("ziwei_tags")
}

// ── RAG 精准召回：多轮会话表 ────────────────────────────
// Redis 快路径（读写）+ MySQL 慢路径（持久化）
model ZiweiSession {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  chartData     Json     @map("chart_data")     // 完整命盘 JSON（iztro 格式）
  chartSummary  String   @map("chart_summary") @db.Text  // 命盘摘要文本（用于 Prompt）
  turns         Json     @default("[]")          // ConversationTurn[]，assistantReply 截断存摘要
  turnCount     Int      @default(0) @map("turn_count")  // 轮次计数，方便查询统计
  currentDomain String   @default("") @map("current_domain") // 当前对话领域
  /** Hybrid 编排：状态机 + stage JSON + 对话历史（程序混合架构） */
  hybridState     Json?    @map("hybrid_state")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  expiresAt     DateTime @map("expires_at")

  @@index([userId])
  @@map("ziwei_sessions")
}

// ── 用户问答记录 ──────────────────────────────────────────
model UserQuestionLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  sessionId    String?  @map("session_id")

  // 问题内容
  question     String   @db.Text
  domain       String?  // 领域：事业/财运/感情/健康/子女/六亲
  intentType   String?  // 意图：normal/offtopic/chitchat

  // 回答内容
  answer       String   @db.LongText
  answerModel  String?  @map("answer_model")

  // 性能数据
  latencyMs    Int?     @map("latency_ms")
  step2Ms      Int?     @map("step2_ms")
  step3Ms      Int?     @map("step3_ms")
  step4Ms      Int?     @map("step4_ms")

  // 命盘指纹
  chartFingerprint String? @map("chart_fingerprint")

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([domain])
  @@index([createdAt])
  @@index([chartFingerprint])
  @@map("user_question_logs")
}

// ── 命主/身份档案 ──────────────────────────────────────────
// 一个 User 可以创建多个命主（自己、家人、朋友等）
model Identity {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  name        String       // 命主姓名
  gender      Gender       // 性别
  birthday    String       // 出生时间（阳历，如 "1990-05-15 14:00"）
  birthCity   String?      @map("birth_city")   // 出生城市
  region      String?      // 出生地区（省份/城市）
  relation    RelationType @default(SELF)       // 与用户的关系
  bazi        String?      // 八字摘要（如 "庚午 辛巳 甲寅 辛未"）
  isActive    Boolean      @default(false) @map("is_active") // 是否为当前活跃命主
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports Report[]
  charts  ChartRecord[]

  @@index([userId])
  @@index([userId, isActive])
  @@map("identities")
}

// ── 命盘档案 ──────────────────────────────────────────────
// 一个 Identity 可有多张盘（多版本/多来源），其中一张为 isPrimary
// chartSnapshot 存完整命盘数据（astrolabe + reading + stage1/2），用于：
//   - AI 对话直接调出（无需重排盘）
//   - 报告生成复用（性能优化）
//   - 合盘分析（双方完整命盘）
model ChartRecord {
  id               String      @id @default(cuid())
  identityId       String      @map("identity_id")
  userId           String      @map("user_id") // 冗余加速查询
  name             String // 盘别名："本人-午时-真太阳时校正" / "母亲-不知时辰猜测版"
  chartSnapshot    Json        @map("chart_snapshot") // { astrolabe, reading, stage1, stage2, computedAt, iztroVersion }
  chartFingerprint String      @map("chart_fingerprint") // sha256(birthday+city+gender+timeIndex)
  birthSolarDate   String      @map("birth_solar_date")
  birthCity        String?     @map("birth_city")
  timeIndex        Int         @map("time_index")
  gender           Gender
  isPrimary        Boolean     @default(false) @map("is_primary")
  note             String?     @db.Text // 用户备注（如"母亲提供的是阴历"）
  source           ChartSource @default(MANUAL)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  identity        Identity              @relation(fields: [identityId], references: [id], onDelete: Cascade)
  compatAsSelf    CompatibilityAnalysis[] @relation("CompatSelf")
  compatAsPartner CompatibilityAnalysis[] @relation("CompatPartner")

  @@index([userId])
  @@index([identityId, isPrimary])
  @@index([chartFingerprint])
  @@map("chart_records")
}

// ── 合盘分析 ──────────────────────────────────────────────
// 同一对组合只存一份（selfChartId + partnerChartId 唯一）
model CompatibilityAnalysis {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  selfChartId    String   @map("self_chart_id")
  partnerChartId String   @map("partner_chart_id")
  result         Json // executeStage4Full 输出（宫位对照/四化交叉/星曜互动/5维评分）
  aiSummary      String?  @db.LongText // AI 完整合盘解读
  createdAt      DateTime @default(now()) @map("created_at")

  selfChart    ChartRecord @relation("CompatSelf", fields: [selfChartId], references: [id], onDelete: Cascade)
  partnerChart ChartRecord @relation("CompatPartner", fields: [partnerChartId], references: [id], onDelete: Cascade)

  @@unique([selfChartId, partnerChartId])
  @@index([userId])
  @@map("compatibility_analyses")
}

// ── 报告模板 ──────────────────────────────────────────────
// 管理员配置的报告模板（体验区/会员区）
model ReportTemplate {
  id           String       @id @default(cuid())
  name         String       // 模板名称
  slug         String       @unique // URL标识，如 "life-full-analysis"
  description  String?      @db.Text // 模板描述
  type         TemplateType @default(BASIC) // BASIC=体验区, ADVANCED=会员区
  tags         Json?        // string[] 标签，如 ["热门","推荐"]
  bgImage      String?      @map("bg_image") // 封面图URL
  sortOrder    Int          @default(0) @map("sort_order") // 排序权重
  isActive     Boolean      @default(true) @map("is_active")
  pointCost    Int          @default(0) @map("point_cost") // 消耗积分
  parentId     String?      @map("parent_id") // 父模板ID（子报告）
  promptConfig String?      @map("prompt_config") @db.Text // 报告生成的 Prompt 配置
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // 自关联：父模板 → 子报告模板
  parent   ReportTemplate?  @relation("TemplateChildren", fields: [parentId], references: [id])
  children ReportTemplate[] @relation("TemplateChildren")

  reports Report[]

  @@index([type, isActive])
  @@index([parentId])
  @@map("report_templates")
}

// ── 报告记录 ──────────────────────────────────────────────
// 用户生成的报告，关联模板和命主
model Report {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  identityId     String       @map("identity_id")
  templateId     String       @map("template_id")
  status         ReportStatus @default(PENDING)
  progress       Int          @default(0) // 生成进度 0-100
  content        String?      @db.LongText // 报告内容 JSON
  coverImage     String?      @map("cover_image") // 封面图URL
  parentReportId String?      @map("parent_report_id") // 父报告ID（子报告）
  errorMessage   String?      @map("error_message") @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity   Identity       @relation(fields: [identityId], references: [id], onDelete: Cascade)
  template   ReportTemplate @relation(fields: [templateId], references: [id])
  parent     Report?        @relation("ReportChildren", fields: [parentReportId], references: [id])
  children   Report[]       @relation("ReportChildren")
  questions  ReportQuestion[]

  @@index([userId, status])
  @@index([identityId])
  @@index([templateId])
  @@index([parentReportId])
  @@map("reports")
}

// ── 报告问答 ──────────────────────────────────────────────
// 基于报告内容的追问
model ReportQuestion {
  id        String   @id @default(cuid())
  reportId  String   @map("report_id")
  userId    String   @map("user_id")
  question  String   @db.Text
  answer    String?  @db.LongText
  createdAt DateTime @default(now()) @map("created_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_questions")
}

// ── 兑换码 ──────────────────────────────────────────────
model RedeemCode {
  id          String   @id @default(cuid())
  code        String   @unique // 兑换码
  pointValue  Int      @map("point_value") // 积分值
  maxUses     Int      @default(1) @map("max_uses") // 最大使用次数
  usedCount   Int      @default(0) @map("used_count") // 已使用次数
  expiresAt   DateTime @map("expires_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  usages RedeemUsage[]

  @@map("redeem_codes")
}

model RedeemUsage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  codeId    String   @map("code_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code RedeemCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@unique([userId, codeId]) // 每个用户只能用一次
  @@map("redeem_usages")
}

// ── 推广/邀请系统 ──────────────────────────────────────────
model PromoterProfile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  inviteCode  String   @unique @map("invite_code") // 推广码
  level       Int      @default(1) // 推广员等级
  totalEarned Int      @default(0) @map("total_earned") // 累计收益（积分）
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      PromoterTeam[]
  earnings  PromoterEarning[]

  @@map("promoter_profiles")
}

model PromoterTeam {
  id          String   @id @default(cuid())
  promoterId  String   @map("promoter_id") // 推广人
  memberId    String   @map("member_id")   // 被邀请人
  joinAt      DateTime @default(now()) @map("join_at")

  promoter PromoterProfile @relation(fields: [promoterId], references: [id], onDelete: Cascade)

  @@unique([promoterId, memberId])
  @@map("promoter_teams")
}

model PromoterEarning {
  id          String   @id @default(cuid())
  promoterId  String   @map("promoter_id")
  userId      String   @map("user_id") // 来源用户
  eventType   String   // 事件类型：register, purchase, upgrade
  points      Int      // 获得积分
  createdAt   DateTime @default(now()) @map("created_at")

  promoter PromoterProfile @relation(fields: [promoterId], references: [id], onDelete: Cascade)

  @@index([promoterId])
  @@map("promoter_earnings")
}
