generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum MembershipPlan {
  FREE
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AnalysisCategory {
  PERSONALITY
  FORTUNE
  MARRIAGE
  CAREER
  HEALTH
  PARENT_CHILD
  EMOTION
}

enum PaymentType {
  MEMBERSHIP
  PER_QUERY
}

enum PaymentChannel {
  WECHAT
  ALIPAY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PointSource {
  SHARE
  ADMIN_GRANT
  REDEEM
}

enum SharePlatform {
  WECHAT
  MOMENTS
}

model User {
  id            String    @id @default(cuid())
  phone         String?   @unique
  email         String?   @unique
  wechatOpenId  String?   @unique @map("wechat_openid")
  nickname      String?
  avatar        String?
  password      String?
  role          UserRole  @default(USER)
  bonusQueries  Int       @default(0) @map("bonus_queries")
  totalPoints   Int       @default(0) @map("total_points")
  inviteCode    String    @unique @map("invite_code")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  username      String?   @unique

  membership          Membership?
  consultationRecords ConsultationRecord[]
  paymentOrders       PaymentOrder[]
  pointRecords        PointRecord[]
  shareRecords        ShareRecord[]
  dailyUsages         DailyUsage[]

  @@map("users")
}

model Membership {
  id        String           @id @default(cuid())
  userId    String           @unique @map("user_id")
  plan      MembershipPlan   @default(FREE)
  status    MembershipStatus @default(ACTIVE)
  startDate DateTime?        @map("start_date")
  endDate   DateTime?        @map("end_date")
  pricePaid Decimal?         @map("price_paid") @db.Decimal(10, 2)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model ConsultationRecord {
  id                String   @id @default(cuid())
  userId            String?  @map("user_id")
  chartFingerprint  String?  @map("chart_fingerprint")
  birthSolarDate    String   @map("birth_solar_date")
  birthLunarDate    String?  @map("birth_lunar_date")
  birthCity         String?  @map("birth_city")
  timeIndex         Int      @map("time_index")
  gender            Gender
  astrolabeData     Json     @map("astrolabe_data")
  createdAt         DateTime @default(now()) @map("created_at")

  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  analyses   AIAnalysis[]

  @@index([userId, chartFingerprint])
  @@map("consultation_records")
}

model AIAnalysis {
  id             String           @id @default(cuid())
  recordId       String           @map("record_id")
  category       AnalysisCategory
  aiModelUsed    String           @map("ai_model_used")
  fullContent    String           @map("full_content") @db.LongText
  previewContent String           @map("preview_content") @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")

  record ConsultationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId, category])
  @@map("ai_analyses")
}

model PaymentOrder {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  type          PaymentType
  amount        Decimal        @db.Decimal(10, 2)
  channel       PaymentChannel
  status        PaymentStatus  @default(PENDING)
  transactionId String?        @map("transaction_id")
  metadata      Json?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_orders")
}

model AIModelConfig {
  id              String  @id @default(cuid())
  name            String
  provider        String
  apiKeyEncrypted String  @map("api_key_encrypted") @db.Text
  baseUrl         String  @map("base_url")
  modelId         String  @map("model_id")
  isActive        Boolean @default(true) @map("is_active")
  isDefault       Boolean @default(false) @map("is_default")
  promptTemplates Json?   @map("prompt_templates")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("ai_model_configs")
}

model PointRecord {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  points    Int
  source    PointSource
  detail    String?
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_records")
}

model ShareRecord {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  platform  SharePlatform
  shareUrl  String        @map("share_url")
  createdAt DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("share_records")
}

model MembershipPricing {
  id            String         @id @default(cuid())
  plan          MembershipPlan
  originalPrice Decimal        @map("original_price") @db.Decimal(10, 2)
  activityPrice Decimal?       @map("activity_price") @db.Decimal(10, 2)
  isActive      Boolean        @default(true) @map("is_active")
  startDate     DateTime?      @map("start_date")
  endDate       DateTime?      @map("end_date")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("membership_pricing")
}

model DailyUsage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_usages")
}

model AdminConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  configValue Json     @map("config_value")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_configs")
}

// ── RAG 精准召回：知识库元数据表 ──────────────────────────
// 与 Zvec 向量双索引：Zvec 做语义检索，MySQL 做精确元数据匹配
model ZiweiKnowledge {
  id          Int      @id @default(autoincrement())
  filePath    String   // 原始文件路径，如 sysfiles/sysknowledge/stars/武曲星.md
  title       String   // 知识标题
  content     String   @db.LongText  // 切片内容
  chunkIndex  Int      @default(0)   // 同文件第几个切片

  // 精确匹配元数据（核心！）
  stars       Json     // string[] 涉及星曜，如 ["武曲"]
  palaces     Json     // string[] 涉及宫位，如 ["命宫","财帛宫"]
  sihua       Json     // string[] 涉及四化类型，如 ["化禄","化忌"]
  domains     Json     // string[] 涉及领域，如 ["财运","事业"]
  patterns    Json     // string[] 涉及格局
  topicType   String   // "星曜本义"|"宫位含义"|"格局"|"四化"|"组合"
  timeScope   String   @default("本命") // "本命"|"大限"|"流年"

  // 向量关联
  vectorId    String?  // Zvec 中对应的向量 ID

  priority    Int      @default(5)  // 1-10，越高越重要
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([filePath, chunkIndex])
  @@index([topicType])
  @@index([timeScope])
  @@map("ziwei_knowledge")
}

// ── RAG 精准召回：标签表（systag 入库）────────────────────
model ZiweiTag {
  id        Int      @id @default(autoincrement())
  tagType   String   // "predict_item" | "star_nature" | "palace_item" | "asterism_item" | "rules_item"
  name      String   // 标签名，如"财运专项"、"十四主星"
  desc      String   @db.Text
  keywords  Json     // string[] 关键词数组
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([name, tagType])
  @@index([tagType])
  @@map("ziwei_tags")
}

// ── RAG 精准召回：多轮会话表 ────────────────────────────
// Redis 快路径（读写）+ MySQL 慢路径（持久化）
model ZiweiSession {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  chartData     Json     @map("chart_data")     // 完整命盘 JSON（iztro 格式）
  chartSummary  String   @map("chart_summary") @db.Text  // 命盘摘要文本（用于 Prompt）
  turns         Json     @default("[]")          // ConversationTurn[]，assistantReply 截断存摘要
  turnCount     Int      @default(0) @map("turn_count")  // 轮次计数，方便查询统计
  currentDomain String   @default("") @map("current_domain") // 当前对话领域
  /** Hybrid 编排：状态机 + stage JSON + 对话历史（程序混合架构） */
  hybridState     Json?    @map("hybrid_state")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  expiresAt     DateTime @map("expires_at")

  @@index([userId])
  @@map("ziwei_sessions")
}

// ── 用户问答记录：问题收录与舆情分析 ──────────────────────
model UserQuestionLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  sessionId    String?  @map("session_id")

  // 问题内容
  question     String   @db.Text
  domain       String?  // 领域：事业/财运/感情/健康/子女/六亲
  intentType   String?  // 意图：normal/offtopic/chitchat

  // 回答内容
  answer       String   @db.LongText
  answerModel  String?  @map("answer_model")

  // 性能数据
  latencyMs    Int?     @map("latency_ms")
  step2Ms      Int?     @map("step2_ms")
  step3Ms      Int?     @map("step3_ms")
  step4Ms      Int?     @map("step4_ms")

  // 命盘指纹
  chartFingerprint String? @map("chart_fingerprint")

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([domain])
  @@index([createdAt])
  @@index([chartFingerprint])
  @@map("user_question_logs")
}

// ── 舆情分析报告 ──────────────────────────────────────────
model SentimentReport {
  id          String   @id @default(cuid())
  reportDate  DateTime @db.Date @map("report_date")  // 报告日期（天）
  keyword     String                             // 统计关键词
  summary     String   @db.Text                 // AI 分析摘要
  trendCount  Int      @default(0) @map("trend_count")      // 本期问题总数
  topDomains  Json     @default("[]") @map("top_domains")    // [{domain, count}]
  topKeywords Json     @default("[]") @map("top_keywords")    // [{question, count}]
  sqlQuery    String?  @map("sql_query") @db.Text             // 生成的 SQL
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([reportDate, keyword])
  @@map("sentiment_reports")
}
