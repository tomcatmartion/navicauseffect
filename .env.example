# 大模型 API Key：请在管理后台「AI 模型」/admin/models 配置（含 MiniMax / DeepSeek / 智谱等），勿在此文件存生产密钥。

# logicdoc 分块重叠比例（0.10–0.15，默认 0.125）
# LOGICDOC_CHUNK_OVERLAP_RATIO="0.125"

# 解盘知识库：已改为 Zvec RAG（须先 npm run sysknowledge:index-zvec 或后台「重建索引」）。可选调 Top-K 与总字数上限：
# LOGICDOC_RAG_TOPK="12"
# LOGICDOC_RAG_MAX_CHARS="14000"
# 命中数低于该值时触发逐级放宽过滤（默认 5）
# LOGICDOC_RAG_RELAX_MIN_HITS="5"
# 设为 0 时关闭：严格命中后仍合并一小批 always/通用 补充池（默认开启）
# LOGICDOC_RAG_RELAX_ALWAYS_POOL="1"
# 设为 0 时禁止「无标量过滤」兜底（生产可关，仅保留 biz 放宽）
# LOGICDOC_RAG_ALLOW_NO_FILTER="1"
# 设为 1 时启用多 query 向量合并（embedding 次数增加）
# LOGICDOC_RAG_MULTIQUERY="0"
# 设为 1 时在 Top 结果旁拉取相邻分块（依赖稳定 chunk id）
# LOGICDOC_RAG_NEIGHBOR_CHUNKS="0"
# 邻接块单块最大字数
# LOGICDOC_RAG_NEIGHBOR_MAX_CHARS="450"
# Zvec 返回 score 低于该值则丢弃（不设则不过滤；余弦相似度约 0~1）
# LOGICDOC_RAG_MIN_SCORE=""
# 词面重排权重 0~1（默认 0.35）
# LOGICDOC_RAG_LEXICAL_WEIGHT="0.35"
# 设为 0 时关闭「星曜/宫位 text like」补充检索（默认开启）
# LOGICDOC_RAG_KEYWORD_SUPPLEMENT="1"
# 设为 1 时在 query 末尾再重复一次用户补充句
# LOGICDOC_RAG_QUERY_REPEAT_USER="0"
# 设为 1 时打印 RAG 过滤链与缓存命中日志
# LOGICDOC_RAG_DEBUG="0"
# 设为 1 时 RAG 增加宫位硬过滤：感情婚姻/情绪/亲子 会放宽为命宫或夫妻宫等；其它类仍为命宫或空宫位数组
# LOGICDOC_RAG_FILTER_MING="0"
# 设为 1 时禁用「无结果则放宽 biz_modules / 去掉过滤」的兜底（默认关闭严格模式）
# LOGICDOC_RAG_STRICT_BIZ_FILTER="0"
# ── 融合检索模式（并行三路召回 + RRF + 标签软加权）──
# legacy（默认）= 标签硬过滤+向量检索；fusion = 并行融合检索
# LOGICDOC_RAG_MODE="legacy"
# 融合模式：纯向量通道 topk（无标签过滤，默认 40）
# LOGICDOC_RAG_FUSION_VECTOR_TOPK="40"
# 融合模式：标签过滤通道 topk（默认 30）
# LOGICDOC_RAG_FUSION_TAG_TOPK="30"
# 融合模式：text like 关键词通道 topk（默认 15）
# LOGICDOC_RAG_FUSION_KW_TOPK="15"
# 融合模式：标签软加权系数 0~1（默认 0.15，匹配标签加分，不匹配不惩罚）
# LOGICDOC_RAG_FUSION_TAG_BOOST="0.15"
# 融合模式：RRF 常数 K（默认 60）
# LOGICDOC_RAG_FUSION_RRF_K="60"
# 索引分块：legacy（默认）| markdown（按 # 标题切段后再字数分块，变更后须重建索引）
# LOGICDOC_CHUNK_STRATEGY="legacy"

# 索引构建时跳过 Zvec optimize（大数据集上可能长时间高 CPU；不设则默认会 optimize）
# LOGICDOC_ZVEC_SKIP_OPTIMIZE="1"

# CLI/本地兜底：未在 AdminConfig 配置 embedding 时使用（管理后台「Embedding」优先）
# EMBEDDING_1536_BASE_URL="https://api.openai.com/v1"
# EMBEDDING_1536_MODEL="text-embedding-3-small"
# EMBEDDING_1536_API_KEY=""
# EMBEDDING_1024_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
# EMBEDDING_1024_MODEL="embedding-3"
# EMBEDDING_1024_API_KEY=""
# Embedding HTTP 超时（毫秒，默认 120000）
# EMBEDDING_FETCH_TIMEOUT_MS="120000"
# 个别网关不接受 encoding_format=float 时设为 1
# EMBEDDING_OMIT_ENCODING_FORMAT="1"
# MiniMax 域名下默认发原生 texts+type；若实际为 OpenAI 兼容代理，设为 1 强制使用 input
# EMBEDDING_FORCE_OPENAI_EMBEDDING_BODY="1"
# MiniMax Group ID 兜底（后台「Embedding」里按维度填写优先）；会写入请求 JSON 的 group_id
# EMBEDDING_MINIMAX_GROUP_ID=""
# 或按维度：EMBEDDING_1536_GROUP_ID / EMBEDDING_1024_GROUP_ID

# 解盘知识库 sysfiles/sysknowledge/ 全量注入已废弃；此项仅影响旧版 loadLogicdocByQuestion（对话）等
# LOGICDOC_MAX_CHARS="32000"

# 解盘：模型单次生成的 max_tokens 上限（默认 4096，原 2048 易中途截断）。按所用模型文档可调大，如 8192
# ANALYSIS_MAX_OUTPUT_TOKENS="4096"

# 解盘：非会员流式界面最多展示多少字（默认 500），会员不受此项限制
# ANALYSIS_STREAM_PREVIEW_CHARS="500"

# 允许模拟支付 API 与 /pricing/mock-pay（生产慎用，勿长期对公网开放）
# ENABLE_MOCK_PAYMENT="true"
