    "@tarojs/runtime": "4.0.9",
    "@tarojs/shared": "4.0.9",
    "@tarojs/taro": "4.0.9",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tarojs/cli": "4.0.9",
    "@tarojs/webpack5-runner": "4.0.9",
    "@types/react": "^18.0.0",
    "@types/webpack-env": "^1.13.0",
    "babel-preset-taro": "4.0.9",
    "react-refresh": "^0.14.0",
    "typescript": "^5.4.0"
