{
  "name": "@navicauseffect/miniprogram",
  "version": "0.1.0",
  "private": true,
  "description": "紫微问道微信小程序（Taro）",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
